---
const data = [
    {
        period: "2022 — Present",
        title: "Software Engineering Manager",
        company: "HOAM Ventures",
        link: "https://www.hoamventures.com",
        description:
            "Leading a team of software developers delivering solutions for Community Archives. Oversee the full development lifecycle — planning, requirements, build, test, deploy — and partner closely with product and design. Equally focused on people: mentoring, coaching, and protecting a collaborative environment where everyone can do their best work.",
    },
    {
        period: "2019 — 2022",
        title: "Software Backend Engineer",
        company: "HOAM Ventures",
        link: "#",
        description:
            "Designed and maintained scalable microservices in Java and Node.js (TypeScript) at TownSq. Worked across MongoDB, AWS, and third-party integrations — owning data integrity, auth, and deployment of cloud-native services in tight collaboration with frontend, product, and stakeholders.",
    },
    {
        period: "2019",
        title: "Software Backend Engineer",
        company: "Neogrid",
        link: "https://www.neogrid.com",
        description:
            "Java backend developer on Neogrid's core software architecture, building Java EE applications deployed on Oracle WebLogic.",
    },
    {
        period: "2016 — 2018",
        title: "Infrastructure Analyst, Intern",
        company: "Neogrid",
        link: "https://www.neogrid.com",
        description:
            "Helped maintain and modernize the infrastructure architecture, managing a VMware cluster that provisioned virtual machines for development teams.",
    },
];
---

<section class="border-t border-base-200 py-16">
    <div class="max-w-[1100px] mx-auto px-8">
        <div class="grid grid-cols-1 md:grid-cols-[220px_1fr] gap-12">
            <div>
                <div class="sticky top-8">
                    <div class="text-[12px] uppercase tracking-[0.14em] font-medium text-base-500">
                        Work
                    </div>
                </div>
            </div>
            <div class="flex flex-col gap-10">
                {
                    data.map((work) => (
                        <article class="grid grid-cols-1 sm:grid-cols-[130px_1fr] gap-2 sm:gap-8">
                            <div>
                                <time class="text-[13px] text-base-500 [font-variant-numeric:tabular-nums] max-sm:text-[12.5px]">
                                    {work.period}
                                </time>
                            </div>
                            <div>
                                <h3 class="text-[17px] font-medium text-base-900 tracking-[-0.005em] leading-[1.35]">
                                    {work.title}
                                </h3>
                                <div class="mt-0.5 text-[15px] text-base-600">
                                    {work.link !== "#" ? (
                                        <a
                                            href={work.link}
                                            target="_blank"
                                            rel="noreferrer"
                                            class="text-base-600 no-underline transition-colors duration-[160ms] hover:text-base-900"
                                        >
                                            <span class="italic">{work.company}</span>
                                            <span aria-hidden="true" class="text-[12px] ml-1.5">↗</span>
                                        </a>
                                    ) : (
                                        <span>
                                            <span class="italic">{work.company}</span>
                                        </span>
                                    )}
                                </div>
                                <p class="text-[14.5px] leading-[1.65] text-base-600 [text-wrap:pretty] mt-3">
                                    {work.description}
                                </p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </div>
</section>
